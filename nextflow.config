/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow configuration — heliuspaired phylogenomics pipeline
    Profiles: slurm (HPC, Apptainer), local (dev/testing)
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

// ── Default parameters ───────────────────────────────────────────────────────
params {
    base_dir     = "/projects/prjs1784/heliuspaired"
    taxon        = null
    samplesheet  = null
    outdir       = null
    core_thresh  = 0.98
    bootstrap    = 1000

    // Resource overrides (optional)
    max_cpus     = 32
    max_memory   = '128 GB'
    max_time     = '24 h'
}

// ── Profiles ─────────────────────────────────────────────────────────────────
profiles {

    slurm {
        process.executor       = 'slurm'
        process.queue          = 'cpu'

        // Use Apptainer (Singularity-compatible) for all processes
        apptainer.enabled      = true
        apptainer.autoMounts   = true
        // Cache pulled images — shared across pipeline runs
        apptainer.cacheDir     = "${params.base_dir}/containers/cache"

        // Retry failed jobs once with more memory
        process.errorStrategy  = 'retry'
        process.maxRetries     = 1

        withName: 'PYRODIGAL' {
            cpus   = 2
            memory = { 4.GB * task.attempt }
            time   = { 1.h  * task.attempt }
        }
        withName: 'PANAROO' {
            cpus   = 16
            memory = { 64.GB * task.attempt }
            time   = { 12.h  * task.attempt }
        }
        withName: 'IQTREE' {
            cpus   = 16
            memory = { 32.GB * task.attempt }
            time   = { 6.h   * task.attempt }
        }
    }

    snellius {
        process {
            executor = 'slurm'
            clusterOptions = '-p genoa'
        }
        executor {
            name = 'slurm'
            queueSize = 70
            submitRateLimit = '10 sec'
            jobName = {
                n = "${task.name}" -> n.replaceAll( '[():\\s]', '_')
            }
        }
        singularity.enabled    = true
        singularity.autoMounts = true
        conda.enabled          = false
        docker.enabled         = false
        podman.enabled         = false
        shifter.enabled        = false
        charliecloud.enabled   = false
        apptainer.enabled      = false

    }

    local {
        process.executor  = 'local'
        apptainer.enabled = true
        apptainer.autoMounts = true

        withName: 'PYRODIGAL' { cpus = 2;  memory = '4 GB';  time = '2 h'  }
        withName: 'PANAROO'   { cpus = 4;  memory = '16 GB'; time = '24 h' }
        withName: 'IQTREE'    { cpus = 4;  memory = '8 GB';  time = '12 h' }
    }

    // Minimal test run: override samplesheet + taxon from command line
    test {
        params.taxon       = 'parabacteroides'
        params.samplesheet = "${params.base_dir}/data/parabacteroides_samplesheet_filtered.csv"
    }
}

// ── Nextflow run reports ─────────────────────────────────────────────────────
def trace_dir = "${params.base_dir}/phylogenomics/${params.taxon ?: 'unknown'}/pipeline_info"

timeline {
    enabled = true
    file    = "${trace_dir}/timeline.html"
    overwrite = true
}
report {
    enabled = true
    file    = "${trace_dir}/report.html"
    overwrite = true
}
trace {
    enabled   = true
    file      = "${trace_dir}/trace.txt"
    overwrite = true
    fields    = 'task_id,name,status,exit,realtime,cpus,memory,disk,rss,vmem'
}
dag {
    enabled   = true
    file      = "${trace_dir}/dag.html"
    overwrite = true
}
